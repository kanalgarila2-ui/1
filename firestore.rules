rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }
    function isBanned() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == true;
    }
    function isFrozen() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isFrozen', false) == true;
    }

    match /passphrases/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if request.auth.uid == userId;
      allow update: if (request.auth.uid == userId && !isBanned()) || isAdmin();
      allow delete: if isAdmin();
    }
    match /chats/{chatId} {
      allow read: if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth() && !isBanned() && request.auth.uid in request.resource.data.members;
      allow update: if isAuth() && request.auth.uid in resource.data.members && !isBanned();
      allow delete: if isAdmin();
    }
    match /messages/{chatId}/msgs/{messageId} {
      allow read: if isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      allow create: if isAuth() && !isBanned() && !isFrozen() &&
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members &&
        request.resource.data.senderId == request.auth.uid;
      // FIX #10: правильная проверка владельца
      allow update: if (request.auth.uid == resource.data.senderId && !isBanned()) || isAdmin();
      allow delete: if isAdmin();
    }
    match /deleted_messages/{messageId} {
      allow read: if isAuth();
      allow write: if isAuth() && !isBanned();
    }
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}
